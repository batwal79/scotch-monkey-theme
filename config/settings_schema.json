      }
    ]
  },
  {
    "name": "Typography",
    "settings": [
      {
        "type": "header",
        "content": "Display / Headings"
      },
      {
        "type": "text",
        "id": "font_heading_family",
        "label": "Heading Font Family",
        "default": "Oswald",
        "info": "ExtraBold (800) only. Do not use lighter weights on dark backgrounds."
      },
      {
        "type": "text",
        "id": "font_heading_letter_spacing",
        "label": "Heading Letter Spacing (em)",
        "default": "0.18",
        "info": "Brand spec: 0.15–0.20em. Enter decimal value."
      },
      {
        "type": "header",
        "content": "Body / UI"
      },
      {
        "type": "text",
        "id": "font_body_family",
        "label": "Body Font Family",
        "default": "Montserrat",
        "info": "Regular (400) for body, Medium (500) for labels/subheadings."
      },
      {
        "type": "range",
        "id": "font_body_size",
        "label": "Base Body Font Size (px)",
        "min": 14,
        "max": 18,
        "step": 1,
        "default": 16,
        "unit": "px"
      },
      {
        "type": "header",
        "content": "Accent Font"
      },
      {
        "type": "text",
        "id": "font_accent_family",
        "label": "Accent Font Family",
        "default": "Playfair Display",
        "info": "Black (900). Taglines, pull quotes, 'Est. MMXXIII' stamps only."
      }
    ]
  },
  {
