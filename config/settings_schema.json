[
  {
    "name": "theme_info",
    "theme_name": "Scotch Monkey",
    "theme_version": "1.0.0",
    "theme_author": "Scotch Monkey",
    "theme_documentation_url": "https://scotchmonkey.com",
    "theme_support_url": "https://scotchmonkey.com"
  },
  {
    "name": "Colors",
    "settings": [
      {
        "type": "color",
        "id": "color_background_primary",
        "label": "Background primary",
        "default": "#0A0A0A",
        "info": "Deep Black — page backgrounds, hero sections"
      },
      {
        "type": "color",
        "id": "color_background_secondary",
        "label": "Background secondary",
        "default": "#2D2D2D",
        "info": "Charcoal — cards, product tiles, footer"
      },
      {
        "type": "color",
        "id": "color_gold_primary",
        "label": "Gold primary",
        "default": "#D4A017",
        "info": "Amber Gold — CTAs, logo accent, highlights"
      },
      {
        "type": "color",
        "id": "color_gold_secondary",
        "label": "Gold secondary",
        "default": "#8B6914",
        "info": "Whisky Brown — hover states, depth, borders"
      },
      {
        "type": "color",
        "id": "color_accent",
        "label": "Accent (urgency only)",
        "default": "#FF2D2D",
        "info": "Electric Red — sale/urgency badges ONLY"
      },
      {
        "type": "color",
        "id": "color_text",
        "label": "Text",
        "default": "#F5F0E8",
        "info": "Cream — body text, headings on dark backgrounds"
      }
    ]
  },
  {
    "name": "Typography",
    "settings": [
      {
        "type": "select",
        "id": "font_heading_weight",
        "label": "Heading font weight",
        "options": [
          { "value": "800", "label": "ExtraBold 800" }
        ],
        "default": "800",
        "info": "Oswald — always 800 on dark backgrounds"
      },
      {
        "type": "range",
        "id": "font_heading_letter_spacing",
        "label": "Heading letter spacing (em × 100)",
        "min": 10,
        "max": 25,
        "step": 1,
        "default": 18,
        "info": "Divide by 100 for em value. 18 = 0.18em"
      }
    ]
  },
  {
    "name": "Layout",
    "settings": [
      {
        "type": "range",
        "id": "page_width",
        "label": "Page width (px)",
        "min": 1000,
        "max": 1600,
        "step": 10,
        "default": 1200
      },
      {
        "type": "range",
        "id": "spacing_sections",
        "label": "Section spacing (px)",
        "min": 20,
        "max": 100,
        "step": 4,
        "default": 60
      }
    ]
  },
  {
    "name": "Favicon & Social Sharing",
    "settings": [
      {
        "type": "image_picker",
        "id": "favicon",
        "label": "Favicon",
        "info": "32×32px PNG. Use Asset 1 — BossyBob geometric icon."
      },
      {
        "type": "image_picker",
        "id": "og_image",
        "label": "Social sharing image (OG)",
        "info": "1200×630px. Shown when the store URL is shared on social media. Use Asset 4 wordmark on black background."
      }
    ]
  },
  {
    "name": "Header",
    "settings": [
      {
        "type": "image_picker",
        "id": "logo",
        "label": "Logo",
        "info": "Use SCOTCH_MONKEY.png (Asset 4) — Oswald wordmark, transparent background"
      },
      {
        "type": "range",
        "id": "logo_width",
        "label": "Logo width (px)",
        "min": 80,
        "max": 300,
        "step": 10,
        "default": 180
      },
      {
        "type": "checkbox",
        "id": "sticky_header",
        "label": "Sticky header",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "show_announcement_bar",
        "label": "Show announcement bar",
        "default": true
      }
    ]
  },
  {
    "name": "Footer",
    "settings": [
      {
        "type": "image_picker",
        "id": "footer_logo",
        "label": "Footer logo",
        "info": "Use SCOTCH_MONKEY.png (Asset 4)"
      },
      {
        "type": "range",
        "id": "footer_logo_width",
        "label": "Footer logo width (px)",
        "min": 60,
        "max": 200,
        "step": 10,
        "default": 140
      },
      {
        "type": "text",
        "id": "footer_tagline",
        "label": "Footer tagline",
        "default": "Blended Culture. Premium Standard."
      },
      {
        "type": "text",
        "id": "footer_copyright",
        "label": "Copyright text",
        "default": "© 2025 Scotch Monkey. All rights reserved."
      }
    ]
  },
  {
    "name": "Social Media",
    "settings": [
      {
        "type": "url",
        "id": "social_instagram",
        "label": "Instagram URL"
      },
      {
        "type": "url",
        "id": "social_tiktok",
        "label": "TikTok URL"
      }
    ]
  },
  {
    "name": "Cart & Shipping",
    "settings": [
      {
        "type": "number",
        "id": "free_shipping_threshold",
        "label": "Free shipping threshold (CAD)",
        "default": 100,
        "info": "Used by cart progress bar and announcement bar"
      },
      {
        "type": "checkbox",
        "id": "show_cart_progress_bar",
        "label": "Show free shipping progress bar in cart",
        "default": true
      }
    ]
  },
  {
    "name": "Product Pages",
    "settings": [
      {
        "type": "checkbox",
        "id": "show_vendor",
        "label": "Show vendor on product page",
        "default": false
      },
      {
        "type": "checkbox",
        "id": "show_sku",
        "label": "Show SKU on product page",
        "default": false
      },
      {
        "type": "checkbox",
        "id": "enable_zoom",
        "label": "Enable image zoom on hover",
        "default": true
      }
    ]
  }
]
