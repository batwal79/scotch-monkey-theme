{%- style -%}
  .image-banner {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: {{ section.settings.content_position }};
    min-height: 50vh;
    overflow: hidden;
    background-color: var(--color-bg-primary);
  }

  .image-banner--tall {
    min-height: 70vh;
  }

  .image-banner--short {
    min-height: 36vh;
  }

  .image-banner__background {
    position: absolute;
    inset: 0;
    z-index: 1;
  }

  .image-banner__background-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .image-banner__overlay {
    position: absolute;
    inset: 0;
    z-index: 2;
  }

  .image-banner__content {
    position: relative;
    z-index: 3;
    padding: 48px var(--layout-gutter);
    max-width: 600px;
    text-align: {{ section.settings.text_alignment }};
  }

  @media (min-width: 768px) {
    .image-banner__content {
      padding: 64px 60px;
    }
  }

  .image-banner__heading {
    font-family: var(--font-heading);
    font-weight: 800;
    font-size: clamp(28px, 5vw, 48px);
    letter-spacing: var(--font-heading-spacing);
    text-transform: uppercase;
    color: var(--color-text);
    line-height: 1.05;
    margin-bottom: 16px;
  }

  .image-banner__text {
    font-size: 15px;
    color: rgba(245, 240, 232, 0.75);
    line-height: 1.6;
    margin-bottom: 28px;
  }
{%- endstyle -%}

{%- liquid
  assign overlay_opacity = section.settings.overlay_opacity | divided_by: 100.0
-%}

<section class="image-banner image-banner--{{ section.settings.height }}" data-section-id="{{ section.id }}">
  {%- if section.settings.image != blank -%}
    <div class="image-banner__background">
      <img
        src="{{ section.settings.image | image_url: width: 2000 }}"
        alt="{{ section.settings.image.alt | default: '' }}"
        class="image-banner__background-image"
        width="2000"
        height="1000"
        loading="lazy"
      >
    </div>
  {%- endif -%}

  <div class="image-banner__overlay" style="background-color: rgba(var(--color-bg-primary-rgb), {{ overlay_opacity }});"></div>

  {%- if section.settings.heading != blank or section.settings.text != blank or section.settings.button_label != blank -%}
    <div class="image-banner__content">
      {%- if section.settings.heading != blank -%}
        <h2 class="image-banner__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}

      {%- if section.settings.text != blank -%}
        <p class="image-banner__text">{{ section.settings.text }}</p>
      {%- endif -%}

      {%- if section.settings.button_label != blank -%}
        <a href="{{ section.settings.button_link }}" class="btn btn--primary">
          {{ section.settings.button_label }}
        </a>
      {%- endif -%}
    </div>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Image Banner",
  "class": "section-image-banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image",
      "info": "Dark, moody lifestyle or atmospheric image. 2000×1000px recommended."
    },
    {
      "type": "select",
      "id": "height",
      "label": "Section height",
      "options": [
        { "value": "tall", "label": "Tall (70vh)" },
        { "value": "medium", "label": "Medium (50vh)" },
        { "value": "short", "label": "Short (36vh)" }
      ],
      "default": "medium"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay opacity (%)",
      "min": 0,
      "max": 90,
      "step": 5,
      "default": 50,
      "unit": "%"
    },
    {
      "type": "select",
      "id": "content_position",
      "label": "Content position",
      "options": [
        { "value": "flex-start", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "flex-end", "label": "Right" }
      ],
      "default": "flex-start"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" }
      ],
      "default": "left"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "BLENDED CULTURE"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Where heritage meets the streets. Premium quality, limited runs, no compromises."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "EXPLORE"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    }
  ],
  "presets": [
    {
      "name": "Image Banner"
    }
  ]
}
{% endschema %}