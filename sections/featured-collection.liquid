{%- style -%}
  .featured-collection {
    background-color: var(--color-bg-primary);
  }

  .featured-collection__header {
    text-align: center;
    margin-bottom: 40px;
  }

  .featured-collection__pre-heading {
    font-family: var(--font-accent);
    font-weight: 900;
    font-style: italic;
    font-size: 14px;
    color: var(--color-gold-primary);
    margin-bottom: 8px;
    letter-spacing: 0;
    text-transform: none;
  }

  .featured-collection__heading {
    font-family: var(--font-heading);
    font-weight: 800;
    font-size: clamp(28px, 4vw, 40px);
    letter-spacing: var(--font-heading-spacing);
    text-transform: uppercase;
    color: var(--color-text);
    margin-bottom: 12px;
  }

  .featured-collection__description {
    font-size: 15px;
    color: rgba(245, 240, 232, 0.6);
    max-width: 480px;
    margin: 0 auto;
    line-height: 1.5;
  }

  /* --- Product Grid --- */
  .featured-collection__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--layout-gutter);
  }

  @media (min-width: 600px) {
    .featured-collection__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .featured-collection__grid--3 {
      grid-template-columns: repeat(3, 1fr);
    }
    .featured-collection__grid--4 {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  /* --- Product Card --- */
  .product-card {
    position: relative;
    display: flex;
    flex-direction: column;
    background-color: var(--color-bg-secondary);
    overflow: hidden;
    transition: transform 0.3s ease;
  }

  .product-card:hover {
    transform: translateY(-4px);
  }

  .product-card__image-wrap {
    position: relative;
    aspect-ratio: 3 / 4;
    overflow: hidden;
    background-color: var(--color-bg-primary);
  }

  .product-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .product-card:hover .product-card__image {
    transform: scale(1.04);
  }

  .product-card__badge {
    position: absolute;
    top: 12px;
    left: 12px;
    z-index: 2;
  }

  .product-card__body {
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 6px;
    flex: 1;
  }

  .product-card__vendor {
    font-family: var(--font-heading);
    font-weight: 800;
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-gold-primary);
  }

  .product-card__title {
    font-family: var(--font-heading);
    font-weight: 800;
    font-size: 16px;
    letter-spacing: var(--font-heading-spacing);
    text-transform: uppercase;
    color: var(--color-text);
    line-height: 1.2;
  }

  .product-card__price {
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 15px;
    color: rgba(245, 240, 232, 0.7);
    margin-top: auto;
    padding-top: 8px;
  }

  .product-card__price--compare {
    text-decoration: line-through;
    color: rgba(245, 240, 232, 0.4);
    margin-right: 8px;
  }

  .product-card__price--sale {
    color: var(--color-accent);
  }

  /* --- CTA --- */
  .featured-collection__cta {
    text-align: center;
    margin-top: 40px;
  }
{%- endstyle -%}

{%- liquid
  assign collection = section.settings.collection
  assign limit = section.settings.products_to_show
  assign columns = section.settings.columns
-%}

<section class="featured-collection section-padding" data-section-id="{{ section.id }}">
  <div class="container">

    <div class="featured-collection__header">
      {%- if section.settings.pre_heading != blank -%}
        <p class="featured-collection__pre-heading">{{ section.settings.pre_heading }}</p>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h2 class="featured-collection__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}

      {%- if section.settings.description != blank -%}
        <p class="featured-collection__description">{{ section.settings.description }}</p>
      {%- endif -%}
    </div>

    {%- if collection != blank and collection.products.size > 0 -%}
      <div class="featured-collection__grid featured-collection__grid--{{ columns }}">
        {%- for product in collection.products limit: limit -%}
          <a href="{{ product.url }}" class="product-card" aria-label="{{ product.title }}">
            <div class="product-card__image-wrap">
              {%- if product.featured_image != blank -%}
                <img
                  src="{{ product.featured_image | image_url: width: 800 }}"
                  alt="{{ product.featured_image.alt | default: product.title }}"
                  class="product-card__image"
                  width="400"
                  height="533"
                  loading="lazy"
                >
              {%- else -%}
                <div style="width:100%;height:100%;background:var(--color-bg-secondary);"></div>
              {%- endif -%}

              {%- if product.compare_at_price > product.price -%}
                <span class="product-card__badge badge badge--sale">SALE</span>
              {%- endif -%}
            </div>

            <div class="product-card__body">
              {%- if section.settings.show_vendor -%}
                <span class="product-card__vendor">{{ product.vendor }}</span>
              {%- endif -%}

              <h3 class="product-card__title">{{ product.title }}</h3>

              <div class="product-card__price">
                {%- if product.compare_at_price > product.price -%}
                  <span class="product-card__price--compare">{{ product.compare_at_price | money }}</span>
                  <span class="product-card__price--sale">{{ product.price | money }}</span>
                {%- else -%}
                  {{ product.price | money }}
                {%- endif -%}
              </div>
            </div>
          </a>
        {%- endfor -%}
      </div>
    {%- else -%}
      {%- comment -%} Placeholder cards when no collection selected {%- endcomment -%}
      <div class="featured-collection__grid featured-collection__grid--{{ columns }}">
        {%- for i in (1..limit) -%}
          <div class="product-card">
            <div class="product-card__image-wrap">
              {{ 'product-' | append: i | placeholder_svg_tag: 'product-card__image' }}
            </div>
            <div class="product-card__body">
              <span class="product-card__vendor">SCOTCH MONKEY</span>
              <h3 class="product-card__title">Product Title</h3>
              <div class="product-card__price">$79.99 CAD</div>
            </div>
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- if section.settings.show_view_all and collection != blank -%}
      <div class="featured-collection__cta">
        <a href="{{ collection.url }}" class="btn btn--outline">
          {{ section.settings.view_all_label }}
        </a>
      </div>
    {%- endif -%}

  </div>
</section>

{% schema %}
{
  "name": "Featured Collection",
  "class": "section-featured-collection",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "pre_heading",
      "label": "Pre-heading (accent font)",
      "default": "Now Available"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "DROP 001"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description"
    },
    {
      "type": "header",
      "content": "Collection"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Products to show",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 4,
      "unit": "x"
    },
    {
      "type": "select",
      "id": "columns",
      "label": "Desktop columns",
      "options": [
        { "value": "2", "label": "2 columns" },
        { "value": "3", "label": "3 columns" },
        { "value": "4", "label": "4 columns" }
      ],
      "default": "4"
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "Show vendor name",
      "default": true
    },
    {
      "type": "header",
      "content": "View All Button"
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "Show 'View All' button",
      "default": true
    },
    {
      "type": "text",
      "id": "view_all_label",
      "label": "Button label",
      "default": "VIEW ALL"
    }
  ],
  "presets": [
    {
      "name": "Featured Collection"
    }
  ]
}
{% endschema %}