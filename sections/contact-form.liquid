{%- style -%}
  .contact-form {
    background-color: var(--color-bg-primary);
  }

  .contact-form__inner {
    max-width: 640px;
    margin: 0 auto;
  }

  .contact-form__pre-heading {
    font-family: var(--font-accent);
    font-weight: 900;
    font-style: italic;
    font-size: 14px;
    color: var(--color-gold-primary);
    margin-bottom: 8px;
    text-align: center;
    letter-spacing: 0;
    text-transform: none;
  }

  .contact-form__heading {
    font-family: var(--font-heading);
    font-weight: 800;
    font-size: clamp(28px, 4vw, 40px);
    letter-spacing: var(--font-heading-spacing);
    text-transform: uppercase;
    color: var(--color-text);
    text-align: center;
    margin-bottom: 12px;
  }

  .contact-form__description {
    font-size: 15px;
    color: rgba(245, 240, 232, 0.6);
    text-align: center;
    max-width: 480px;
    margin: 0 auto 40px;
    line-height: 1.6;
  }

  .contact-form__fields {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .contact-form__row {
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
  }

  @media (min-width: 600px) {
    .contact-form__row {
      grid-template-columns: 1fr 1fr;
    }
  }

  .contact-form__field label {
    display: block;
    font-family: var(--font-heading);
    font-weight: 800;
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text);
    margin-bottom: 8px;
  }

  .contact-form__field input,
  .contact-form__field textarea {
    width: 100%;
    padding: 12px 16px;
    font-family: var(--font-body);
    font-size: 15px;
    color: var(--color-text);
    background-color: var(--color-bg-secondary);
    border: 1px solid var(--color-bg-secondary);
    transition: border-color 0.25s ease;
  }

  .contact-form__field input:focus,
  .contact-form__field textarea:focus {
    outline: none;
    border-color: var(--color-gold-primary);
  }

  .contact-form__field input::placeholder,
  .contact-form__field textarea::placeholder {
    color: rgba(245, 240, 232, 0.3);
  }

  .contact-form__field textarea {
    min-height: 140px;
    resize: vertical;
  }

  .contact-form__submit {
    text-align: center;
    margin-top: 8px;
  }

  .contact-form__success {
    text-align: center;
    padding: 40px 0;
  }

  .contact-form__success-heading {
    font-family: var(--font-heading);
    font-weight: 800;
    font-size: 24px;
    letter-spacing: var(--font-heading-spacing);
    text-transform: uppercase;
    color: var(--color-gold-primary);
    margin-bottom: 12px;
  }

  .contact-form__success-text {
    font-size: 15px;
    color: rgba(245, 240, 232, 0.6);
  }
{%- endstyle -%}

<section class="contact-form section-padding" data-section-id="{{ section.id }}">
  <div class="container">
    <div class="contact-form__inner">

      {%- if section.settings.pre_heading != blank -%}
        <p class="contact-form__pre-heading">{{ section.settings.pre_heading }}</p>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h2 class="contact-form__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}

      {%- if section.settings.description != blank -%}
        <p class="contact-form__description">{{ section.settings.description }}</p>
      {%- endif -%}

      {%- form 'contact', id: 'contact-form' -%}
        {%- if form.posted_successfully? -%}
          <div class="contact-form__success">
            <h3 class="contact-form__success-heading">MESSAGE SENT</h3>
            <p class="contact-form__success-text">Thanks for reaching out. We'll get back to you within 24–48 hours.</p>
          </div>
        {%- else -%}
          {%- if form.errors -%}
            <div class="form-errors" style="margin-bottom:24px;padding:16px;border:1px solid var(--color-accent);color:var(--color-accent);font-size:14px;">
              {{ form.errors | default_errors }}
            </div>
          {%- endif -%}

          <div class="contact-form__fields">
            <div class="contact-form__row">
              <div class="contact-form__field">
                <label for="contact-name">NAME</label>
                <input type="text" id="contact-name" name="contact[name]" placeholder="Your name" required>
              </div>
              <div class="contact-form__field">
                <label for="contact-email">EMAIL</label>
                <input type="email" id="contact-email" name="contact[email]" placeholder="you@email.com" required>
              </div>
            </div>

            <div class="contact-form__field">
              <label for="contact-subject">SUBJECT</label>
              <input type="text" id="contact-subject" name="contact[subject]" placeholder="Order inquiry, general question, etc.">
            </div>

            <div class="contact-form__field">
              <label for="contact-body">MESSAGE</label>
              <textarea id="contact-body" name="contact[body]" placeholder="How can we help?" required></textarea>
            </div>

            <div class="contact-form__submit">
              <button type="submit" class="btn btn--primary">SEND MESSAGE</button>
            </div>
          </div>
        {%- endif -%}
      {%- endform -%}

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Contact Form",
  "class": "section-contact-form",
  "settings": [
    {
      "type": "text",
      "id": "pre_heading",
      "label": "Pre-heading (accent font)",
      "default": "Get In Touch"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "CONTACT US"
    },
    {
      "type": "text",
      "id": "description",
      "label": "Description",
      "default": "Have a question about your order, sizing, or anything else? Drop us a line."
    }
  ],
  "presets": [
    {
      "name": "Contact Form"
    }
  ]
}
{% endschema %}