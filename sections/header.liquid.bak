{%- style -%}
  .header {
    position: sticky;
    top: 0;
    z-index: 100;
    background-color: var(--color-bg-primary);
    border-bottom: 1px solid var(--color-bg-secondary);
  }

  .header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
    padding-left: var(--layout-gutter);
    padding-right: var(--layout-gutter);
    max-width: var(--layout-max-width);
    margin: 0 auto;
  }

  @media (min-width: 768px) {
    .header__inner {
      height: 72px;
    }
  }

  /* --- Logo --- */
  .header__logo {
    flex-shrink: 0;
  }

  .header__logo-link {
    display: flex;
    align-items: center;
  }

  .header__logo-img {
    height: 28px;
    width: auto;
  }

  @media (min-width: 768px) {
    .header__logo-img {
      height: 34px;
    }
  }

  /* --- Desktop Nav --- */
  .header__nav {
    display: none;
    gap: 32px;
  }

  @media (min-width: 768px) {
    .header__nav {
      display: flex;
    }
  }

  .header__nav-link {
    font-family: var(--font-heading);
    font-weight: 800;
    font-size: 13px;
    letter-spacing: var(--font-heading-spacing);
    text-transform: uppercase;
    color: var(--color-text);
    position: relative;
    padding: 4px 0;
    transition: color 0.25s ease;
  }

  .header__nav-link::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 2px;
    background-color: var(--color-gold-primary);
    transition: width 0.3s ease;
  }

  .header__nav-link:hover {
    color: var(--color-gold-primary);
  }

  .header__nav-link:hover::after {
    width: 100%;
  }

  /* --- Icons area --- */
  .header__icons {
    display: flex;
    align-items: center;
    gap: 16px;
    flex-shrink: 0;
  }

  .header__icon-btn {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    color: var(--color-text);
    transition: color 0.25s ease;
  }

  .header__icon-btn:hover {
    color: var(--color-gold-primary);
  }

  .header__icon-btn svg {
    width: 22px;
    height: 22px;
    stroke: currentColor;
    stroke-width: 1.5;
    fill: none;
  }

  .header__cart-count {
    position: absolute;
    top: 2px;
    right: 2px;
    min-width: 16px;
    height: 16px;
    padding: 0 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-body);
    font-size: 10px;
    font-weight: 500;
    line-height: 1;
    color: var(--color-bg-primary);
    background-color: var(--color-gold-primary);
    border-radius: 8px;
  }

  /* --- Hamburger --- */
  .header__menu-toggle {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 40px;
    height: 40px;
    padding: 8px;
  }

  @media (min-width: 768px) {
    .header__menu-toggle {
      display: none;
    }
  }

  .header__menu-toggle span {
    display: block;
    width: 100%;
    height: 2px;
    background-color: var(--color-text);
    transition: all 0.3s ease;
    transform-origin: center;
  }

  .header__menu-toggle[aria-expanded="true"] span:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }

  .header__menu-toggle[aria-expanded="true"] span:nth-child(2) {
    opacity: 0;
  }

  .header__menu-toggle[aria-expanded="true"] span:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  /* --- Mobile Drawer --- */
  .header__mobile-drawer {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 99;
    pointer-events: none;
    visibility: hidden;
  }

  .header__mobile-drawer[data-open="true"] {
    pointer-events: auto;
    visibility: visible;
  }

  .header__drawer-overlay {
    position: absolute;
    inset: 0;
    background-color: rgba(0, 0, 0, 0.6);
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .header__mobile-drawer[data-open="true"] .header__drawer-overlay {
    opacity: 1;
  }

  .header__drawer-panel {
    position: absolute;
    top: 0;
    right: 0;
    width: 300px;
    max-width: 85vw;
    height: 100%;
    background-color: var(--color-bg-primary);
    border-left: 1px solid var(--color-bg-secondary);
    transform: translateX(100%);
    transition: transform 0.3s ease;
    display: flex;
    flex-direction: column;
    overflow-y: auto;
  }

  .header__mobile-drawer[data-open="true"] .header__drawer-panel {
    transform: translateX(0);
  }

  .header__drawer-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px var(--layout-gutter);
    border-bottom: 1px solid var(--color-bg-secondary);
  }

  .header__drawer-close {
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text);
  }

  .header__drawer-close svg {
    width: 20px;
    height: 20px;
    stroke: currentColor;
    stroke-width: 1.5;
    fill: none;
  }

  .header__drawer-nav {
    padding: 24px var(--layout-gutter);
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .header__drawer-link {
    display: block;
    padding: 14px 0;
    font-family: var(--font-heading);
    font-weight: 800;
    font-size: 18px;
    letter-spacing: var(--font-heading-spacing);
    text-transform: uppercase;
    color: var(--color-text);
    border-bottom: 1px solid var(--color-bg-secondary);
    transition: color 0.25s ease;
  }

  .header__drawer-link:hover {
    color: var(--color-gold-primary);
  }
{%- endstyle -%}

<header class="header" data-section-id="{{ section.id }}">
  <div class="header__inner">

    {%- comment -%} Hamburger — mobile only {%- endcomment -%}
    <button
      class="header__menu-toggle"
      aria-expanded="false"
      aria-controls="mobile-drawer-{{ section.id }}"
      aria-label="Open menu"
      data-menu-toggle
    >
      <span></span>
      <span></span>
      <span></span>
    </button>

    {%- comment -%} Logo — Asset 4: Oswald Wordmark {%- endcomment -%}
    <div class="header__logo">
      <a href="{{ routes.root_url }}" class="header__logo-link" aria-label="{{ shop.name }}">
        {%- if section.settings.logo != blank -%}
          <img
            src="{{ section.settings.logo | image_url: height: 68 }}"
            alt="{{ shop.name }}"
            class="header__logo-img"
            width="{{ section.settings.logo.width }}"
            height="34"
            loading="eager"
          >
        {%- else -%}
          <span
            class="header__logo-text heading"
            style="font-size: 20px; letter-spacing: var(--font-heading-spacing);"
          >
            {{ shop.name | upcase }}
          </span>
        {%- endif -%}
      </a>
    </div>

    {%- comment -%} Desktop nav {%- endcomment -%}
    <nav class="header__nav" aria-label="Main navigation">
      {%- for link in section.settings.menu.links -%}
        <a href="{{ link.url }}" class="header__nav-link">
          {{ link.title }}
        </a>
      {%- endfor -%}
    </nav>

    {%- comment -%} Icons {%- endcomment -%}
    <div class="header__icons">
      <a href="{{ routes.cart_url }}" class="header__icon-btn" aria-label="Cart ({{ cart.item_count }} items)">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4zM3 6h18M16 10a4 4 0 01-8 0"/>
        </svg>
        {%- if cart.item_count > 0 -%}
          <span class="header__cart-count">{{ cart.item_count }}</span>
        {%- endif -%}
      </a>
    </div>
  </div>

  {%- comment -%} Mobile drawer {%- endcomment -%}
  <div
    class="header__mobile-drawer"
    id="mobile-drawer-{{ section.id }}"
    data-mobile-drawer
  >
    <div class="header__drawer-overlay" data-drawer-overlay></div>
    <div class="header__drawer-panel">
      <div class="header__drawer-header">
        <span
          class="heading"
          style="font-size: 16px; letter-spacing: var(--font-heading-spacing);"
        >
          MENU
        </span>
        <button class="header__drawer-close" aria-label="Close menu" data-drawer-close>
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M18 6L6 18M6 6l12 12"/>
          </svg>
        </button>
      </div>
      <nav class="header__drawer-nav" aria-label="Mobile navigation">
        {%- for link in section.settings.menu.links -%}
          <a href="{{ link.url }}" class="header__drawer-link">
            {{ link.title }}
          </a>
        {%- endfor -%}
      </nav>
    </div>
  </div>
</header>

<script>
  (function() {
    const section = document.querySelector('[data-section-id="{{ section.id }}"]');
    if (!section) return;

    const toggle = section.querySelector('[data-menu-toggle]');
    const drawer = section.querySelector('[data-mobile-drawer]');
    const overlay = section.querySelector('[data-drawer-overlay]');
    const closeBtn = section.querySelector('[data-drawer-close]');

    function openDrawer() {
      drawer.setAttribute('data-open', 'true');
      toggle.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
    }

    function closeDrawer() {
      drawer.setAttribute('data-open', 'false');
      toggle.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
    }

    toggle.addEventListener('click', function() {
      const isOpen = drawer.getAttribute('data-open') === 'true';
      isOpen ? closeDrawer() : openDrawer();
    });

    overlay.addEventListener('click', closeDrawer);
    closeBtn.addEventListener('click', closeDrawer);

    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && drawer.getAttribute('data-open') === 'true') {
        closeDrawer();
      }
    });
  })();
</script>

{% schema %}
{
  "name": "Header",
  "class": "section-header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image",
      "info": "Use Asset 4 — Oswald Wordmark (SCOTCH_MONKEY.png). Upload at 2x (minimum 400px wide)."
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Navigation menu",
      "default": "main-menu"
    }
  ]
}
{% endschema %}