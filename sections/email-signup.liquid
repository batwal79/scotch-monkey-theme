{%- style -%}
  .email-signup {
    position: relative;
    background-color: var(--color-bg-secondary);
    overflow: hidden;
  }

  .email-signup__background {
    position: absolute;
    inset: 0;
    z-index: 1;
  }

  .email-signup__background-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.15;
  }

  .email-signup__inner {
    position: relative;
    z-index: 2;
    text-align: center;
    max-width: 560px;
    margin: 0 auto;
  }

  .email-signup__icon {
    max-width: 80px;
    height: auto;
    margin: 0 auto 24px;
    opacity: 0.9;
  }

  .email-signup__pre-heading {
    font-family: var(--font-accent);
    font-weight: 900;
    font-style: italic;
    font-size: 14px;
    color: var(--color-gold-primary);
    margin-bottom: 8px;
    letter-spacing: 0;
    text-transform: none;
  }

  .email-signup__heading {
    font-family: var(--font-heading);
    font-weight: 800;
    font-size: clamp(28px, 4vw, 40px);
    letter-spacing: var(--font-heading-spacing);
    text-transform: uppercase;
    color: var(--color-text);
    line-height: 1.1;
    margin-bottom: 12px;
  }

  .email-signup__text {
    font-size: 15px;
    color: rgba(245, 240, 232, 0.65);
    line-height: 1.6;
    margin-bottom: 28px;
  }

  .email-signup__form {
    display: flex;
    gap: 0;
    max-width: 440px;
    margin: 0 auto 16px;
  }

  .email-signup__input {
    flex: 1;
    padding: 14px 18px;
    font-family: var(--font-body);
    font-size: 14px;
    color: var(--color-text);
    background-color: var(--color-bg-primary);
    border: 1px solid var(--color-gold-secondary);
    border-right: none;
  }

  .email-signup__input::placeholder {
    color: rgba(245, 240, 232, 0.35);
  }

  .email-signup__input:focus {
    outline: none;
    border-color: var(--color-gold-primary);
  }

  .email-signup__btn {
    padding: 14px 28px;
    font-family: var(--font-heading);
    font-weight: 800;
    font-size: 13px;
    letter-spacing: var(--font-heading-spacing);
    text-transform: uppercase;
    color: var(--color-bg-primary);
    background-color: var(--color-gold-primary);
    border: 1px solid var(--color-gold-primary);
    cursor: pointer;
    white-space: nowrap;
    transition: all 0.25s ease;
  }

  .email-signup__btn:hover {
    background-color: var(--color-gold-secondary);
    border-color: var(--color-gold-secondary);
  }

  .email-signup__fine-print {
    font-size: 12px;
    color: rgba(245, 240, 232, 0.35);
    line-height: 1.5;
  }

  .email-signup__success {
    display: none;
    padding: 16px;
    font-family: var(--font-heading);
    font-weight: 800;
    font-size: 14px;
    letter-spacing: var(--font-heading-spacing);
    text-transform: uppercase;
    color: var(--color-gold-primary);
  }
{%- endstyle -%}

<section class="email-signup section-padding" data-section-id="{{ section.id }}">
  {%- if section.settings.background_image != blank -%}
    <div class="email-signup__background">
      <img
        src="{{ section.settings.background_image | image_url: width: 1600 }}"
        alt=""
        class="email-signup__background-image"
        width="1600"
        height="800"
        loading="lazy"
      >
    </div>
  {%- endif -%}

  <div class="container">
    <div class="email-signup__inner">

      {%- if section.settings.icon_image != blank -%}
        <img
          src="{{ section.settings.icon_image | image_url: width: 160 }}"
          alt=""
          class="email-signup__icon"
          width="80"
          height="80"
          loading="lazy"
        >
      {%- endif -%}

      {%- if section.settings.pre_heading != blank -%}
        <p class="email-signup__pre-heading">{{ section.settings.pre_heading }}</p>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h2 class="email-signup__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}

      {%- if section.settings.text != blank -%}
        <p class="email-signup__text">{{ section.settings.text }}</p>
      {%- endif -%}

      {%- form 'customer', id: 'email-signup-form' -%}
        <input type="hidden" name="contact[tags]" value="newsletter,homepage">
        <div class="email-signup__form">
          <input
            type="email"
            name="contact[email]"
            class="email-signup__input"
            placeholder="{{ section.settings.placeholder }}"
            autocomplete="email"
            aria-label="Email address"
            required
          >
          <button type="submit" class="email-signup__btn">
            {{ section.settings.button_text }}
          </button>
        </div>
      {%- endform -%}

      {%- if section.settings.fine_print != blank -%}
        <p class="email-signup__fine-print">{{ section.settings.fine_print }}</p>
      {%- endif -%}

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Email Signup",
  "class": "section-email-signup",
  "settings": [
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image (optional)",
      "info": "Will display at 15% opacity behind content."
    },
    {
      "type": "image_picker",
      "id": "icon_image",
      "label": "Icon / mascot (optional)",
      "info": "Use Asset 1 (Mascot Icon). Displays at 80px centered."
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "pre_heading",
      "label": "Pre-heading (accent font)",
      "default": "Don't Miss a Drop"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "JOIN THE DROP LIST"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Description",
      "default": "First access to new drops, restocks, and exclusives. No spam, just heat."
    },
    {
      "type": "text",
      "id": "placeholder",
      "label": "Input placeholder",
      "default": "Enter your email"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "JOIN"
    },
    {
      "type": "text",
      "id": "fine_print",
      "label": "Fine print",
      "default": "By subscribing, you agree to receive marketing emails. Unsubscribe anytime."
    }
  ],
  "presets": [
    {
      "name": "Email Signup"
    }
  ]
}
{% endschema %}