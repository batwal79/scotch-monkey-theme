{%- style -%}
  .brand-story {
    background-color: var(--color-bg-primary);
    overflow: hidden;
  }

  .brand-story__inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: 40px;
    align-items: center;
  }

  @media (min-width: 768px) {
    .brand-story__inner {
      grid-template-columns: 1fr 1fr;
      gap: 64px;
    }

    .brand-story__inner--reversed {
      direction: rtl;
    }

    .brand-story__inner--reversed > * {
      direction: ltr;
    }
  }

  .brand-story__image-wrap {
    position: relative;
    aspect-ratio: 4 / 5;
    overflow: hidden;
    background-color: var(--color-bg-primary);
  }

  .brand-story__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .brand-story__image-accent {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 4px;
    background: linear-gradient(to right, var(--color-gold-primary), var(--color-gold-secondary));
  }

  .brand-story__content {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .brand-story__pre-heading {
    font-family: var(--font-accent);
    font-weight: 900;
    font-style: italic;
    font-size: 14px;
    color: var(--color-gold-primary);
    letter-spacing: 0;
    text-transform: none;
  }

  .brand-story__heading {
    font-family: var(--font-heading);
    font-weight: 800;
    font-size: clamp(28px, 4vw, 40px);
    letter-spacing: var(--font-heading-spacing);
    text-transform: uppercase;
    color: var(--color-text);
    line-height: 1.1;
  }

  .brand-story__divider {
    width: 60px;
    height: 2px;
    background-color: var(--color-gold-primary);
  }

  .brand-story__text {
    font-size: 15px;
    line-height: 1.7;
    color: rgba(245, 240, 232, 0.75);
  }

  .brand-story__text p + p {
    margin-top: 1em;
  }

  .brand-story__quote {
    font-family: var(--font-accent);
    font-weight: 900;
    font-style: italic;
    font-size: clamp(18px, 2.5vw, 22px);
    color: var(--color-gold-primary);
    line-height: 1.4;
    letter-spacing: 0;
    text-transform: none;
    padding-left: 20px;
    border-left: 3px solid var(--color-gold-secondary);
  }
{%- endstyle -%}

<section class="brand-story section-padding" data-section-id="{{ section.id }}">
  <div class="container">
    <div class="brand-story__inner{% if section.settings.image_position == 'right' %} brand-story__inner--reversed{% endif %}">

      {%- comment -%} Image side {%- endcomment -%}
      <div class="brand-story__image-wrap">
        {%- if section.settings.image != blank -%}
          <img
            src="{{ section.settings.image | image_url: width: 1000 }}"
            alt="{{ section.settings.image.alt | default: section.settings.heading }}"
            class="brand-story__image"
            width="500"
            height="625"
            loading="lazy"
          >
        {%- endif -%}
        <div class="brand-story__image-accent"></div>
      </div>

      {%- comment -%} Text side {%- endcomment -%}
      <div class="brand-story__content">
        {%- if section.settings.pre_heading != blank -%}
          <p class="brand-story__pre-heading">{{ section.settings.pre_heading }}</p>
        {%- endif -%}

        {%- if section.settings.heading != blank -%}
          <h2 class="brand-story__heading">{{ section.settings.heading }}</h2>
        {%- endif -%}

        <div class="brand-story__divider"></div>

        {%- if section.settings.text != blank -%}
          <div class="brand-story__text">{{ section.settings.text }}</div>
        {%- endif -%}

        {%- if section.settings.quote != blank -%}
          <blockquote class="brand-story__quote">{{ section.settings.quote }}</blockquote>
        {%- endif -%}

        {%- if section.settings.button_label != blank -%}
          <div>
            <a href="{{ section.settings.button_link }}" class="btn btn--outline">
              {{ section.settings.button_label }}
            </a>
          </div>
        {%- endif -%}
      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Brand Story",
  "class": "section-brand-story",
  "settings": [
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image",
      "info": "Use Asset 3 (Script Lockup), mascot, or atmospheric brand image. 1000×1250px."
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Image position (desktop)",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "pre_heading",
      "label": "Pre-heading (accent font)",
      "default": "Est. MMXXIII"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "THE STORY"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Body text",
      "default": "<p>Scotch Monkey was born from a simple idea: streetwear should feel as premium as the culture it represents. Rooted in Scottish heritage and blended with contemporary street culture, every piece is designed to make a statement without saying a word.</p><p>We don't chase trends. We set a standard. Limited drops, premium blanks, no compromises.</p>"
    },
    {
      "type": "text",
      "id": "quote",
      "label": "Pull quote (accent font)",
      "default": "Blended Culture. Premium Standard."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "OUR STORY"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    }
  ],
  "presets": [
    {
      "name": "Brand Story"
    }
  ]
}
{% endschema %}
