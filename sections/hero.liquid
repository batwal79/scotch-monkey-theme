{%- style -%}
  .hero {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 100vh;
    min-height: 100svh;
    overflow: hidden;
    background-color: var(--color-bg-primary);
  }

  .hero--medium {
    min-height: 75vh;
    min-height: 75svh;
  }

  .hero--small {
    min-height: 60vh;
    min-height: 60svh;
  }

  .hero__background {
    position: absolute;
    inset: 0;
    z-index: 1;
  }

  .hero__background-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero__overlay {
    position: absolute;
    inset: 0;
    z-index: 2;
    background: linear-gradient(
      to bottom,
      rgba(var(--color-bg-primary-rgb), 0.4) 0%,
      rgba(var(--color-bg-primary-rgb), 0.7) 50%,
      rgba(var(--color-bg-primary-rgb), 0.9) 100%
    );
  }

  .hero__content {
    position: relative;
    z-index: 3;
    text-align: center;
    padding: 40px var(--layout-gutter);
    max-width: 800px;
  }

  .hero__logo {
    max-width: 320px;
    height: auto;
    margin: 0 auto 32px;
  }

  @media (min-width: 768px) {
    .hero__logo {
      max-width: 440px;
      margin-bottom: 40px;
    }
  }

  .hero__pre-heading {
    font-family: var(--font-accent);
    font-weight: 900;
    font-style: italic;
    font-size: clamp(14px, 2vw, 18px);
    color: var(--color-gold-primary);
    margin-bottom: 12px;
    text-transform: none;
    letter-spacing: 0;
  }

  .hero__heading {
    font-family: var(--font-heading);
    font-weight: 800;
    font-size: clamp(36px, 7vw, 64px);
    letter-spacing: var(--font-heading-spacing);
    text-transform: uppercase;
    line-height: 1.05;
    color: var(--color-text);
    margin-bottom: 16px;
  }

  .hero__subheading {
    font-family: var(--font-body);
    font-weight: 400;
    font-size: clamp(14px, 1.8vw, 17px);
    color: rgba(245, 240, 232, 0.7);
    line-height: 1.5;
    margin-bottom: 32px;
    max-width: 520px;
    margin-left: auto;
    margin-right: auto;
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 12px;
  }
{%- endstyle -%}

<section class="hero hero--{{ section.settings.height }}" data-section-id="{{ section.id }}">
  {%- if section.settings.background_image != blank -%}
    <div class="hero__background">
      <img
        src="{{ section.settings.background_image | image_url: width: 2000 }}"
        alt="{{ section.settings.background_image.alt | default: '' }}"
        class="hero__background-image"
        width="2000"
        height="1200"
        loading="eager"
        fetchpriority="high"
      >
    </div>
  {%- endif -%}

  <div class="hero__overlay"></div>

  <div class="hero__content">
    {%- if section.settings.logo_image != blank -%}
      <img
        src="{{ section.settings.logo_image | image_url: width: 880 }}"
        alt="{{ shop.name }}"
        class="hero__logo"
        width="440"
        height="auto"
        loading="eager"
      >
    {%- endif -%}

    {%- if section.settings.pre_heading != blank -%}
      <p class="hero__pre-heading">{{ section.settings.pre_heading }}</p>
    {%- endif -%}

    {%- if section.settings.heading != blank -%}
      <h1 class="hero__heading">{{ section.settings.heading }}</h1>
    {%- endif -%}

    {%- if section.settings.subheading != blank -%}
      <p class="hero__subheading">{{ section.settings.subheading }}</p>
    {%- endif -%}

    <div class="hero__actions">
      {%- if section.settings.button_label != blank -%}
        <a href="{{ section.settings.button_link }}" class="btn btn--primary">
          {{ section.settings.button_label }}
        </a>
      {%- endif -%}

      {%- if section.settings.button_label_2 != blank -%}
        <a href="{{ section.settings.button_link_2 }}" class="btn btn--outline">
          {{ section.settings.button_label_2 }}
        </a>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "class": "section-hero",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "height",
      "label": "Section height",
      "options": [
        { "value": "full", "label": "Full screen" },
        { "value": "medium", "label": "Medium (75vh)" },
        { "value": "small", "label": "Small (60vh)" }
      ],
      "default": "full"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image",
      "info": "Use a dark, moody atmospheric image. 2000×1200px recommended."
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "image_picker",
      "id": "logo_image",
      "label": "Logo / graphic",
      "info": "Use Asset 3 (Script Lockup) or Asset 4 (Wordmark). Displayed centered above text."
    },
    {
      "type": "text",
      "id": "pre_heading",
      "label": "Pre-heading (accent font)",
      "default": "Est. MMXXIII — Premium Streetwear"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "DROP 001 IS HERE"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Premium streetwear crafted at the intersection of heritage and culture. Limited pieces. No restocks."
    },
    {
      "type": "header",
      "content": "Primary Button"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "SHOP DROP 001"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Secondary Button"
    },
    {
      "type": "text",
      "id": "button_label_2",
      "label": "Button label",
      "default": "VIEW LOOKBOOK"
    },
    {
      "type": "url",
      "id": "button_link_2",
      "label": "Button link"
    }
  ],
  "presets": [
    {
      "name": "Hero"
    }
  ]
}
{% endschema %}