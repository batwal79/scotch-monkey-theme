{%- style -%}
  /* === PRODUCT PAGE === */
  .main-product {
    background-color: var(--color-bg-primary);
  }

  .main-product__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 32px;
  }

  @media (min-width: 768px) {
    .main-product__grid {
      grid-template-columns: 1fr 1fr;
      gap: 48px;
      align-items: start;
    }
  }

  @media (min-width: 1024px) {
    .main-product__grid {
      grid-template-columns: 1.15fr 0.85fr;
      gap: 64px;
    }
  }

  /* --- Gallery --- */
  .product-gallery {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  @media (min-width: 768px) {
    .product-gallery {
      position: sticky;
      top: 88px;
    }
  }

  .product-gallery__main {
    position: relative;
    aspect-ratio: 3 / 4;
    background-color: var(--color-bg-secondary);
    overflow: hidden;
  }

  .product-gallery__main-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    cursor: zoom-in;
    transition: transform 0.3s ease;
  }

  .product-gallery__main-image:hover {
    transform: scale(1.03);
  }

  .product-gallery__thumbs {
    display: flex;
    gap: 8px;
    overflow-x: auto;
    scrollbar-width: none;
    -ms-overflow-style: none;
    padding-bottom: 4px;
  }

  .product-gallery__thumbs::-webkit-scrollbar {
    display: none;
  }

  .product-gallery__thumb {
    flex: 0 0 72px;
    width: 72px;
    height: 96px;
    background-color: var(--color-bg-secondary);
    overflow: hidden;
    cursor: pointer;
    border: 2px solid transparent;
    transition: border-color 0.25s ease;
    padding: 0;
  }

  .product-gallery__thumb.is-active,
  .product-gallery__thumb:hover {
    border-color: var(--color-gold-primary);
  }

  .product-gallery__thumb-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .product-gallery__badge {
    position: absolute;
    top: 12px;
    left: 12px;
    z-index: 2;
  }

  /* --- Product Info --- */
  .product-info {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .product-info__vendor {
    font-family: var(--font-heading);
    font-weight: 800;
    font-size: 12px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-gold-primary);
    margin-bottom: 8px;
  }

  .product-info__title {
    font-family: var(--font-heading);
    font-weight: 800;
    font-size: clamp(24px, 3.5vw, 36px);
    letter-spacing: var(--font-heading-spacing);
    text-transform: uppercase;
    color: var(--color-text);
    line-height: 1.1;
    margin-bottom: 16px;
  }

  .product-info__price {
    display: flex;
    align-items: baseline;
    gap: 12px;
    margin-bottom: 24px;
  }

  .product-info__price-current {
    font-family: var(--font-heading);
    font-weight: 800;
    font-size: 24px;
    letter-spacing: 0.05em;
    color: var(--color-text);
  }

  .product-info__price-compare {
    font-size: 16px;
    text-decoration: line-through;
    color: rgba(245, 240, 232, 0.4);
  }

  .product-info__price-badge {
    margin-left: 4px;
  }

  .product-info__divider {
    width: 100%;
    height: 1px;
    background-color: var(--color-bg-secondary);
    margin: 4px 0 24px;
  }

  .product-info__description {
    font-size: 15px;
    line-height: 1.7;
    color: rgba(245, 240, 232, 0.7);
    margin-bottom: 24px;
  }

  .product-info__description p + p {
    margin-top: 1em;
  }

  /* --- Variant Selector --- */
  .variant-selector {
    margin-bottom: 24px;
  }

  .variant-selector__label {
    display: block;
    font-family: var(--font-heading);
    font-weight: 800;
    font-size: 12px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text);
    margin-bottom: 10px;
  }

  .variant-selector__label span {
    font-family: var(--font-body);
    font-weight: 400;
    text-transform: none;
    letter-spacing: 0;
    color: rgba(245, 240, 232, 0.5);
    margin-left: 6px;
  }

  .variant-selector__options {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .variant-selector__option {
    display: flex;
    align-items: center;
    justify-content: center;
    min-width: 48px;
    padding: 10px 16px;
    font-family: var(--font-heading);
    font-weight: 800;
    font-size: 13px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text);
    background-color: transparent;
    border: 1px solid var(--color-bg-secondary);
    cursor: pointer;
    transition: all 0.25s ease;
  }

  .variant-selector__option:hover {
    border-color: var(--color-gold-secondary);
  }

  .variant-selector__option.is-selected {
    border-color: var(--color-gold-primary);
    color: var(--color-gold-primary);
  }

  .variant-selector__option.is-unavailable {
    opacity: 0.3;
    cursor: not-allowed;
    text-decoration: line-through;
  }

  /* --- Quantity + ATC --- */
  .product-form__actions {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-bottom: 24px;
  }

  .product-form__row {
    display: flex;
    gap: 12px;
  }

  .quantity-selector {
    display: flex;
    align-items: center;
    border: 1px solid var(--color-bg-secondary);
    flex-shrink: 0;
  }

  .quantity-selector__btn {
    width: 44px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 18px;
    color: var(--color-text);
    transition: color 0.25s ease;
  }

  .quantity-selector__btn:hover {
    color: var(--color-gold-primary);
  }

  .quantity-selector__input {
    width: 48px;
    height: 48px;
    text-align: center;
    font-family: var(--font-heading);
    font-weight: 800;
    font-size: 14px;
    color: var(--color-text);
    background: transparent;
    border: none;
    border-left: 1px solid var(--color-bg-secondary);
    border-right: 1px solid var(--color-bg-secondary);
    -moz-appearance: textfield;
  }

  .quantity-selector__input::-webkit-inner-spin-button,
  .quantity-selector__input::-webkit-outer-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }

  .product-form__atc {
    flex: 1;
    padding: 14px 32px;
    font-family: var(--font-heading);
    font-weight: 800;
    font-size: 14px;
    letter-spacing: var(--font-heading-spacing);
    text-transform: uppercase;
    color: var(--color-bg-primary);
    background-color: var(--color-gold-primary);
    border: 2px solid var(--color-gold-primary);
    cursor: pointer;
    transition: all 0.25s ease;
    line-height: 1;
    height: 48px;
  }

  .product-form__atc:hover {
    background-color: var(--color-gold-secondary);
    border-color: var(--color-gold-secondary);
  }

  .product-form__atc:disabled {
    opacity: 0.4;
    cursor: not-allowed;
  }

  .product-form__dynamic-checkout {
    margin-bottom: 24px;
  }

  .product-form__dynamic-checkout .shopify-payment-button__button {
    border-radius: 0 !important;
    min-height: 48px;
  }

  /* --- Collapsible Content --- */
  .collapsible {
    border-top: 1px solid var(--color-bg-secondary);
  }

  .collapsible:last-child {
    border-bottom: 1px solid var(--color-bg-secondary);
  }

  .collapsible__trigger {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    padding: 18px 0;
    font-family: var(--font-heading);
    font-weight: 800;
    font-size: 13px;
    letter-spacing: var(--font-heading-spacing);
    text-transform: uppercase;
    color: var(--color-text);
    text-align: left;
    cursor: pointer;
    transition: color 0.25s ease;
  }

  .collapsible__trigger:hover {
    color: var(--color-gold-primary);
  }

  .collapsible__icon {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
    stroke: currentColor;
    stroke-width: 2;
    fill: none;
    transition: transform 0.3s ease;
  }

  .collapsible[open] .collapsible__icon {
    transform: rotate(45deg);
  }

  .collapsible__content {
    padding-bottom: 20px;
    font-size: 14px;
    line-height: 1.7;
    color: rgba(245, 240, 232, 0.65);
  }

  .collapsible__content p + p {
    margin-top: 0.75em;
  }
{%- endstyle -%}

{%- liquid
  assign current_variant = product.selected_or_first_available_variant
  assign featured_image = current_variant.featured_image | default: product.featured_image
-%}

<section class="main-product section-padding" data-section-id="{{ section.id }}">
  <div class="container">
    <div class="main-product__grid">

      {%- comment -%} ====== GALLERY ====== {%- endcomment -%}
      <div class="product-gallery" data-product-gallery>
        <div class="product-gallery__main">
          {%- if product.compare_at_price > product.price -%}
            <span class="product-gallery__badge badge badge--sale">SALE</span>
          {%- endif -%}

          {%- if featured_image != blank -%}
            <img
              src="{{ featured_image | image_url: width: 1200 }}"
              alt="{{ featured_image.alt | default: product.title }}"
              class="product-gallery__main-image"
              id="product-main-image"
              width="600"
              height="800"
              loading="eager"
            >
          {%- else -%}
            <div style="width:100%;height:100%;background:var(--color-bg-secondary);display:flex;align-items:center;justify-content:center;">
              {{ 'product-1' | placeholder_svg_tag }}
            </div>
          {%- endif -%}
        </div>

        {%- if product.images.size > 1 -%}
          <div class="product-gallery__thumbs">
            {%- for image in product.images -%}
              <button
                class="product-gallery__thumb{% if image == featured_image %} is-active{% endif %}"
                data-thumb-index="{{ forloop.index0 }}"
                data-thumb-src="{{ image | image_url: width: 1200 }}"
                data-thumb-alt="{{ image.alt | default: product.title }}"
                aria-label="View image {{ forloop.index }}"
              >
                <img
                  src="{{ image | image_url: width: 160 }}"
                  alt="{{ image.alt | default: product.title }}"
                  class="product-gallery__thumb-image"
                  width="72"
                  height="96"
                  loading="lazy"
                >
              </button>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>

      {%- comment -%} ====== PRODUCT INFO ====== {%- endcomment -%}
      <div class="product-info">
        {%- if product.vendor != blank -%}
          <p class="product-info__vendor">{{ product.vendor }}</p>
        {%- endif -%}

        <h1 class="product-info__title">{{ product.title }}</h1>

        <div class="product-info__price" data-product-price>
          <span class="product-info__price-current" data-price>
            {{ current_variant.price | money }}
          </span>
          {%- if current_variant.compare_at_price > current_variant.price -%}
            <span class="product-info__price-compare" data-compare-price>
              {{ current_variant.compare_at_price | money }}
            </span>
            <span class="product-info__price-badge badge badge--sale">SALE</span>
          {%- endif -%}
        </div>

        <div class="product-info__divider"></div>

        {%- if product.description != blank -%}
          <div class="product-info__description">
            {{ product.description }}
          </div>
        {%- endif -%}

        {%- comment -%} ====== VARIANT SELECTORS ====== {%- endcomment -%}
        {%- form 'product', product, id: 'product-form', data-product-form: '' -%}
          <input type="hidden" name="id" value="{{ current_variant.id }}" data-variant-id>
          <input type="hidden" name="return_to" value="/cart">

          {%- unless product.has_only_default_variant -%}
            {%- for option in product.options_with_values -%}
              <div class="variant-selector">
                <label class="variant-selector__label">
                  {{ option.name }}<span data-selected-option="{{ forloop.index0 }}">{{ option.selected_value }}</span>
                </label>
                <div class="variant-selector__options" data-option-group="{{ forloop.index0 }}">
                  {%- for value in option.values -%}
                    <button
                      type="button"
                      class="variant-selector__option{% if value == option.selected_value %} is-selected{% endif %}"
                      data-option-value="{{ value }}"
                      data-option-index="{{ forloop.parentloop.index0 }}"
                      aria-label="{{ option.name }}: {{ value }}"
                    >
                      {{ value }}
                    </button>
                  {%- endfor -%}
                </div>
              </div>
            {%- endfor -%}
          {%- endunless -%}

          <div class="product-form__actions">
            <div class="product-form__row">
              <div class="quantity-selector">
                <button type="button" class="quantity-selector__btn" data-qty-minus aria-label="Decrease quantity">−</button>
                <input
                  type="number"
                  name="quantity"
                  class="quantity-selector__input"
                  value="1"
                  min="1"
                  max="99"
                  data-qty-input
                  aria-label="Quantity"
                >
                <button type="button" class="quantity-selector__btn" data-qty-plus aria-label="Increase quantity">+</button>
              </div>

              <button
                type="submit"
                class="product-form__atc"
                {% unless current_variant.available %}disabled{% endunless %}
                data-atc-btn
              >
                {%- if current_variant.available -%}
                  ADD TO CART
                {%- else -%}
                  SOLD OUT
                {%- endif -%}
              </button>
            </div>

            <div class="product-form__dynamic-checkout">
              {{ form | payment_button }}
            </div>
          </div>
        {%- endform -%}

        {%- comment -%} ====== COLLAPSIBLE BLOCKS ====== {%- endcomment -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'collapsible' -%}
            <details class="collapsible" {{ block.shopify_attributes }}{% if block.settings.open_by_default %} open{% endif %}>
              <summary class="collapsible__trigger">
                {{ block.settings.heading }}
                <svg class="collapsible__icon" viewBox="0 0 16 16" aria-hidden="true">
                  <line x1="8" y1="2" x2="8" y2="14"/>
                  <line x1="2" y1="8" x2="14" y2="8"/>
                </svg>
              </summary>
              <div class="collapsible__content">
                {{ block.settings.content }}
              </div>
            </details>
          {%- endif -%}
        {%- endfor -%}

      </div>
    </div>
  </div>
</section>

<script>
(function() {
  const section = document.querySelector('[data-section-id="{{ section.id }}"]');
  if (!section) return;

  const productJson = {{ product.variants | json }};
  const variantIdInput = section.querySelector('[data-variant-id]');
  const priceEl = section.querySelector('[data-price]');
  const comparePriceEl = section.querySelector('[data-compare-price]');
  const atcBtn = section.querySelector('[data-atc-btn]');
  const mainImage = document.getElementById('product-main-image');
  const thumbs = section.querySelectorAll('[data-thumb-src]');
  const optionBtns = section.querySelectorAll('.variant-selector__option');
  const selectedLabels = section.querySelectorAll('[data-selected-option]');

  /* --- Thumbnail gallery --- */
  thumbs.forEach(function(thumb) {
    thumb.addEventListener('click', function() {
      if (!mainImage) return;
      mainImage.src = this.getAttribute('data-thumb-src');
      mainImage.alt = this.getAttribute('data-thumb-alt') || '';
      thumbs.forEach(function(t) { t.classList.remove('is-active'); });
      this.classList.add('is-active');
    });
  });

  /* --- Quantity --- */
  const qtyInput = section.querySelector('[data-qty-input]');
  const qtyMinus = section.querySelector('[data-qty-minus]');
  const qtyPlus = section.querySelector('[data-qty-plus]');

  if (qtyMinus && qtyPlus && qtyInput) {
    qtyMinus.addEventListener('click', function() {
      const v = parseInt(qtyInput.value) || 1;
      if (v > 1) qtyInput.value = v - 1;
    });
    qtyPlus.addEventListener('click', function() {
      const v = parseInt(qtyInput.value) || 1;
      if (v < 99) qtyInput.value = v + 1;
    });
  }

  /* --- Variant selection --- */
  function getSelectedOptions() {
    var options = [];
    section.querySelectorAll('[data-option-group]').forEach(function(group) {
      var selected = group.querySelector('.is-selected');
      options.push(selected ? selected.getAttribute('data-option-value') : '');
    });
    return options;
  }

  function findVariant(options) {
    return productJson.find(function(v) {
      return v.option1 === options[0] &&
             (options.length < 2 || v.option2 === options[1]) &&
             (options.length < 3 || v.option3 === options[2]);
    });
  }

  function formatMoney(cents) {
    return '$' + (cents / 100).toFixed(2) + ' CAD';
  }

  function updateVariant(variant) {
    if (!variant) return;

    variantIdInput.value = variant.id;
    priceEl.textContent = formatMoney(variant.price);

    if (comparePriceEl) {
      if (variant.compare_at_price && variant.compare_at_price > variant.price) {
        comparePriceEl.textContent = formatMoney(variant.compare_at_price);
        comparePriceEl.style.display = '';
      } else {
        comparePriceEl.style.display = 'none';
      }
    }

    if (variant.available) {
      atcBtn.disabled = false;
      atcBtn.textContent = 'ADD TO CART';
    } else {
      atcBtn.disabled = true;
      atcBtn.textContent = 'SOLD OUT';
    }

    /* Update URL without reload */
    var url = new URL(window.location);
    url.searchParams.set('variant', variant.id);
    window.history.replaceState({}, '', url);

    /* Update featured image if variant has one */
    if (variant.featured_image && mainImage) {
      mainImage.src = variant.featured_image.src.replace(/(\.[^.]+)$/, '_1200x$1');
    }
  }

  optionBtns.forEach(function(btn) {
    btn.addEventListener('click', function() {
      var group = this.closest('[data-option-group]');
      group.querySelectorAll('.variant-selector__option').forEach(function(b) {
        b.classList.remove('is-selected');
      });
      this.classList.add('is-selected');

      /* Update label */
      var idx = this.getAttribute('data-option-index');
      var label = section.querySelector('[data-selected-option="' + idx + '"]');
      if (label) label.textContent = this.getAttribute('data-option-value');

      var options = getSelectedOptions();
      var variant = findVariant(options);
      if (variant) updateVariant(variant);
    });
  });
})();
</script>

{% schema %}
{
  "name": "Product Page",
  "class": "section-main-product",
  "settings": [],
  "blocks": [
    {
      "type": "collapsible",
      "name": "Collapsible Tab",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Details"
        },
        {
          "type": "richtext",
          "id": "content",
          "label": "Content",
          "default": "<p>Add product details, materials, care instructions, or sizing information here.</p>"
        },
        {
          "type": "checkbox",
          "id": "open_by_default",
          "label": "Open by default",
          "default": false
        }
      ]
    }
  ],
  "default": {
    "blocks": [
      {
        "type": "collapsible",
        "settings": {
          "heading": "Details & Materials",
          "content": "<p>420 GSM heavyweight fleece. Independent Trading Co. IND420XD blank. DTG printed graphic. Pre-shrunk cotton-polyester blend.</p>",
          "open_by_default": true
        }
      },
      {
        "type": "collapsible",
        "settings": {
          "heading": "Sizing",
          "content": "<p>True to size. For an oversized fit, size up one. See our Size Guide for detailed measurements.</p>"
        }
      },
      {
        "type": "collapsible",
        "settings": {
          "heading": "Shipping & Returns",
          "content": "<p>Free shipping on orders over $100 CAD. Printed on demand — please allow 5–10 business days for production plus shipping. All sales final on printed-to-order items.</p>"
        }
      }
    ]
  },
  "disabled_on": {
    "groups": ["header", "footer"]
  }
}
{% endschema %}