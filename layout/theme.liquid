<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="theme-color" content="#0A0A0A">

    {%- if settings.favicon -%}
      <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32, crop: 'center' }}">
      <link rel="apple-touch-icon" href="{{ settings.favicon | image_url: width: 180, height: 180, crop: 'center' }}">
    {%- endif -%}

    <title>
      {{ page_title }}
      {%- if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif -%}
      {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif -%}
      {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
    </title>

    {%- if page_description -%}
      <meta name="description" content="{{ page_description | escape }}">
    {%- endif -%}

    {%- comment -%} Open Graph {%- endcomment -%}
    <meta property="og:site_name" content="{{ shop.name }}">
    <meta property="og:title" content="{{ page_title | escape }}">
    <meta property="og:type" content="website">
    <meta property="og:url" content="{{ canonical_url }}">

    {%- if template == 'product' and product.featured_image -%}
      <meta property="og:type" content="product">
      <meta property="og:image" content="{{ product.featured_image | image_url: width: 1200 }}">
      <meta property="og:image:width" content="1200">
      <meta property="og:image:height" content="1200">
    {%- elsif settings.og_image -%}
      <meta property="og:image" content="{{ settings.og_image | image_url: width: 1200 }}">
      <meta property="og:image:width" content="1200">
      <meta property="og:image:height" content="630">
    {%- endif -%}

    {%- if page_description -%}
      <meta property="og:description" content="{{ page_description | escape }}">
    {%- endif -%}

    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="{{ page_title | escape }}">
    {%- if settings.og_image -%}
      <meta name="twitter:image" content="{{ settings.og_image | image_url: width: 1200 }}">
    {%- endif -%}

    {{ content_for_header }}

    {%- comment -%} Google Fonts {%- endcomment -%}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Oswald:wght@800&family=Montserrat:wght@400;500&family=Playfair+Display:ital,wght@1,900&display=swap" rel="stylesheet">

    <style>
      :root {
        /* Brand colors — locked per creative direction */
        --color-bg-primary: #0A0A0A;
        --color-bg-secondary: #2D2D2D;
        --color-gold-primary: #D4A017;
        --color-gold-secondary: #8B6914;
        --color-accent: #FF2D2D;
        --color-text: #F5F0E8;

        /* Typography */
        --font-heading: 'Oswald', sans-serif;
        --font-body: 'Montserrat', sans-serif;
        --font-accent: 'Playfair Display', serif;
        --font-heading-weight: 800;
        --font-heading-spacing: 0.18em;
        --font-body-size: 15px;

        /* Layout */
        --layout-max-width: 1200px;
        --layout-gutter: 20px;
        --section-spacing: 60px;
      }

      @media (min-width: 768px) {
        :root {
          --layout-gutter: 40px;
          --font-body-size: 16px;
        }
      }

      @media (min-width: 1024px) {
        :root {
          --layout-gutter: 60px;
        }
      }
    </style>

    {{ 'critical.css' | asset_url | stylesheet_tag }}
  </head>

  <body class="template-{{ template.name }}{% if template.suffix %} template-{{ template.name }}-{{ template.suffix }}{% endif %}">

    <a class="skip-to-content" href="#MainContent">Skip to content</a>

    {%- sections 'header-group' -%}

    <main id="MainContent" class="main-content" role="main" tabindex="-1">
      {{ content_for_layout }}
    </main>

    {%- sections 'footer-group' -%}

    {{ 'global.js' | asset_url | script_tag }}

  </body>
</html>
